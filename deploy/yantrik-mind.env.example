# yantrik-mind environment — copy to /etc/yantrik-mind.env on the host, fill in, chmod 600.
# NEVER commit the filled-in version. Real secrets stay on the box only.

# --- Inference backend (NanoGPT; falls back to claude CLI, then scripted) ---
NANOGPT_KEY=__nanogpt_key__
YM_MODEL=deepseek/deepseek-v4-pro-cheaper

# --- Identity ---
YM_OPERATOR=Pranab

# --- Persistence (under StateDirectory so it survives restarts) ---
YM_DB=/var/lib/yantrik-mind/mind.db
YM_TG_OFFSET=/var/lib/yantrik-mind/tg_offset

# --- Telegram channel ---
YM_TELEGRAM_TOKEN=__telegram_bot_token__
# Optional: lock to one chat id (else first chatter is accepted)
# YM_TELEGRAM_CHAT=

# --- Email (read inbox + gated send). Gmail needs a 16-char App Password. ---
YM_EMAIL=yantrikdb@gmail.com
YM_EMAIL_PASSWORD=__gmail_app_password_no_spaces__
# Optional non-standard IMAP host: YM_IMAP_HOST=

# --- GitHub (read notifications + gated comment). Dedicated bot PAT. ---
YM_GITHUB_TOKEN=__github_pat__

# --- Proactive reminders ---
# YM_REMINDERS=off    # to disable
# YM_QUIET_START=22
# YM_QUIET_END=7
