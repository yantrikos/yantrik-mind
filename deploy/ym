#!/usr/bin/env bash
# ym — your terminal line to yantrik-mind (LIVE: shares the running companion's memory & continuity).
# Top-level dispatcher: `ym <name> <args>`. Command routing is done SERVER-SIDE (the registry is
# data-driven from the skill store), so a new capability skill becomes a new `ym` command with no
# client change. A few pure-infra ops (logs/deploy/status) stay here since they're SSH/systemd, not
# agent operations. The chat/command endpoint is localhost-only on the box → SSH is the trust boundary.
set -uo pipefail
BOX="${YM_BOX:-root@192.168.4.90}"
KEY="${YM_KEY:-$HOME/.ssh/id_deploy}"
CTL="${YM_CTL_URL:-http://127.0.0.1:8077}"
ssh_box() { ssh -i "$KEY" -o ConnectTimeout=8 "$BOX" "$@"; }
# Forward a line to the server-side router; the message is piped via stdin so quotes/spaces never hit a shell.
ym_send() { printf '%s' "$1" | ssh_box "curl -s -m 150 --data-binary @- $CTL/cli"; echo; }

cmd="${1:-}"; [ $# -gt 0 ] && shift

case "$cmd" in
  status)
    printf 'service:  '; ssh_box 'systemctl is-active yantrik-mind'
    printf 'endpoint: '; ssh_box "curl -s -m 6 $CTL/status || echo UNREACHABLE"
    ;;
  logs)
    ssh_box "journalctl -u yantrik-mind --no-pager ${*:--n 40}"
    ;;
  deploy)
    ssh_box 'cd /root/codes/yantrik-mind && CARGO_HOME=/root/.cargo RUSTUP_HOME=/root/.rustup PATH=/usr/local/bin:/root/.cargo/bin:/usr/bin:/bin cargo build --release -p mind-core 2>&1 | tail -2 && systemctl stop yantrik-mind && cp target/release/mind-core /opt/yantrik-mind/mind-core && chown yantrikmind:yantrikmind /opt/yantrik-mind/mind-core && systemctl start yantrik-mind && sleep 3 && systemctl is-active yantrik-mind'
    ;;
  ""|-h|--help|help)
    echo "ym — talk to yantrik-mind (live, shared memory)"
    echo "  ym <message...>       chat with the running companion"
    echo "  ym <command> <args>   run a command (core or skill-registered)"
    echo "  ym commands           list all commands (core + skills, data-driven)"
    echo "  ym status             service + control-endpoint health"
    echo "  ym logs [-f] [-n N]   companion logs"
    echo "  ym deploy             build + stop/cp/start"
    echo
    ym_send "commands"
    ;;
  *)
    # Everything else (home, recall, remember, <skill> <target>, or free chat) → server-side router.
    ym_send "$cmd $*"
    ;;
esac
